<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<title>Quiz Histoire</title>

<style>
body {
  margin: 0;
  font-family: "Segoe UI", Arial, sans-serif;
  background: linear-gradient(135deg, #1f1c2c, #928dab);
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  color: white;
}

/* 🧩 Carte principale */
.box {
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(12px);
  border-radius: 16px;
  padding: 25px;
  width: 420px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.3);
  text-align: center;
  animation: fadeIn 0.5s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

/* 🏷️ Niveau */
#level {
  font-size: 14px;
  opacity: 0.8;
  margin-bottom: 5px;
}

/* ❓ Question */
#question {
  font-size: 20px;
  margin-bottom: 20px;
}

/* 🖼️ Image */
#image img {
  max-width: 100%;
  border-radius: 10px;
  margin-bottom: 15px;
}

/* 🔘 Réponses */
button {
  display: block;
  width: 100%;
  margin: 10px 0;
  padding: 12px;
  border: none;
  border-radius: 10px;
  background: rgba(255,255,255,0.15);
  color: white;
  font-size: 15px;
  cursor: pointer;
  transition: 0.2s;
}

button:hover {
  transform: scale(1.02);
  background: rgba(255,255,255,0.25);
}

button:active {
  transform: scale(0.98);
}

/* 🎯 Bouton suivant */
.box > button:last-of-type {
  margin-top: 15px;
  background: #00c896;
}

.box > button:last-of-type:hover {
  background: #00e0a8;
}
</style>

</head>

<body>

<div class="box">
  <h4 id="level"></h4>
  <h2 id="question"></h2>
  <div id="image"></div>
  <div id="answers"></div>
  <button onclick="nextQuestion()">Suivant</button>
</div>

<script>

let audioCtx;

function initAudio() {
  if (!audioCtx) {
    audioCtx = new (window.AudioContext || window.webkitAudioContext)();
  }
}

function goodSound() {
  initAudio();

  const osc1 = audioCtx.createOscillator();
  const osc2 = audioCtx.createOscillator();
  const gain = audioCtx.createGain();

  osc1.type = "sine";
  osc2.type = "sine";

  osc1.frequency.setValueAtTime(800, audioCtx.currentTime);
  osc2.frequency.setValueAtTime(1200, audioCtx.currentTime);

  gain.gain.setValueAtTime(0.12, audioCtx.currentTime);
  gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.2);

  osc1.connect(gain);
  osc2.connect(gain);
  gain.connect(audioCtx.destination);

  osc1.start();
  osc2.start();

  osc1.stop(audioCtx.currentTime + 0.2);
  osc2.stop(audioCtx.currentTime + 0.2);
}

function badSound() {
  initAudio();

  const osc = audioCtx.createOscillator();
  const gain = audioCtx.createGain();

  osc.type = "triangle";
  osc.frequency.setValueAtTime(300, audioCtx.currentTime);
  osc.frequency.exponentialRampToValueAtTime(180, audioCtx.currentTime + 0.25);

  gain.gain.setValueAtTime(0.12, audioCtx.currentTime);
  gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.25);

  osc.connect(gain);
  gain.connect(audioCtx.destination);

  osc.start();
  osc.stop(audioCtx.currentTime + 0.25);
}

function shuffle(array) {
  return array
    .map(v => ({ v, s: Math.random() }))
    .sort((a, b) => a.s - b.s)
    .map(({ v }) => v);
}

/* 📚 TES QUESTIONS (inchangées) */
const quiz = [
  {
    level: 1,
    question: "Quel pays est opposé à la France durant la guerre de Cent Ans ?",
    answers: ["Angleterre", "Espagne", "Saint-Empire romain germanique"],
    correctAnswer: "Angleterre"
  },
  {
    level: 1,
    question: "Surnommée « la pucelle d’Orléans », quelle jeune femme aide Charles VII ?",
    answers: ["Jeanne d'Arc", "Aliénor d'Aquitaine", "Blanche de Castille"],
    correctAnswer: "Jeanne d'Arc"
  },
  {
    level: 2,
    question: "Quelle dynastie royale est au pouvoir en France durant ce conflit ?",
    answers: ["Valois", "Bourbon", "Capétiens directs"],
    correctAnswer: "Valois"
  },
  {
    level: 2,
    question: "Prénommé Bertrand, quel noble breton fut connétable de France ?",
    answers: ["Bertrand du Guesclin", "Bertrand de Goth", "Bertrand Russell"],
    correctAnswer: "Bertrand du Guesclin"
  },
  {
    level: 3,
    question: "Quelle dynastie est au pouvoir en Angleterre au début de la guerre de Cent Ans ?",
    answers: ["Plantagenêt", "Tudor", "Stuart"],
    correctAnswer: "Plantagenêt"
  },
  {
    level: 3,
    question: "Quel roi est capturé à Poitiers en 1356 ?",
    answers: ["Jean II le Bon", "Charles V", "Philippe VI"],
    correctAnswer: "Jean II le Bon"
  },
  {
    level: 4,
    question: "Dernière bataille du conflit (1453) ?",
    answers: ["Castillon", "Azincourt", "Bouvines"],
    correctAnswer: "Castillon"
  },
  {
    level: 4,
    question: "En quelle année Charles VII est-il sacré ?",
    answers: ["1429", "1431", "1453"],
    correctAnswer: "1429"
  }
];

let current = 0;
let score = 0;
let answered = false;

function loadQuestion() {
  answered = false;

  const q = quiz[current];

  document.getElementById("level").innerText = "Niveau " + q.level;
  document.getElementById("question").innerText = q.question;

  document.getElementById("image").innerHTML = "";

  const div = document.getElementById("answers");
  div.innerHTML = "";

  const shuffled = shuffle(q.answers);

  shuffled.forEach((a) => {
    const btn = document.createElement("button");
    btn.innerText = a;

    btn.onclick = () => {
      if (answered) return;
      answered = true;

      if (a === q.correctAnswer) {
        score++;
        btn.style.background = "rgba(0, 255, 150, 0.4)";
        goodSound();
      } else {
        btn.style.background = "rgba(255, 80, 80, 0.4)";
        badSound();
      }
    };

    div.appendChild(btn);
  });
}

function nextQuestion() {
  if (!answered) {
    alert("Réponds d'abord !");
    return;
  }

  current++;

  if (current < quiz.length) {
    loadQuestion();
  } else {
    document.body.innerHTML = `
      <div class="box">
        <h1>🎮 Quiz terminé</h1>
        <h2>Score : ${score}/${quiz.length}</h2>
        <button onclick="location.reload()">Rejouer</button>
      </div>
    `;
  }
}

loadQuestion();

</script>

</body>
</html>
